# =============================================================================
# Example configuration: serverless PrivateLink to an internal Kafka cluster
# =============================================================================

# AWS region for deployment. Determines the environment: commercial (e.g.
# us-east-1) or GovCloud (us-gov-west-1), and thus which Databricks serverless
# private-connectivity role is allowlisted on the VPC endpoint service.
region = "us-gov-west-1"

# GovCloud shard: "civilian" or "dod". Required when region is us-gov-west-1;
# leave null (or omit) for commercial regions.
databricks_gov_shard = null

# Prefix used for naming and tagging resources.
resource_prefix = ""

# VPC that can reach the Kafka brokers and where the NLB is created.
vpc_id = ""

# Subnets (one per AZ) for the internal NLB. Use at least two AZs.
nlb_subnet_ids = ["", ""]

# Kafka brokers to expose. Each broker gets its own dedicated nlb_port so
# serverless clients can address individual brokers after bootstrap. Set each
# broker's advertised.listeners to the endpoint private DNS name + its nlb_port.
brokers = [
  {
    name       = "broker-0"
    ip_address = "10.0.1.10"
    port       = 9094
    nlb_port   = 9094
  },
  {
    name       = "broker-1"
    ip_address = "10.0.2.10"
    port       = 9094
    nlb_port   = 9095
  },
  {
    name       = "broker-2"
    ip_address = "10.0.3.10"
    port       = 9094
    nlb_port   = 9096
  },
]

# Optional: override the allowlisted principals. Defaults to the Databricks
# serverless private-connectivity role for the selected shard. Use ["*"] for the
# simplified allow-all approach from the Databricks docs.
# allowed_principals = ["*"]

# Optional: require manual acceptance of connection requests (recommended).
# acceptance_required = true
